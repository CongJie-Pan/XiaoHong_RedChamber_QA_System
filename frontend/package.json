{
  "name": "perplexity_qa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const fs=require('fs'); if(fs.existsSync('../.env')) fs.copyFileSync('../.env', '.env.local')\"",
    "dev": "next dev",
    "prebuild": "node -e \"const fs=require('fs'); if(fs.existsSync('../.env')) fs.copyFileSync('../.env', '.env.local')\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "lint:report": "node -e \"require('fs').mkdirSync('lintAndTypeError_Check',{recursive:true})\" && eslint . > lintAndTypeError_Check/lint-report.txt 2>&1 || echo lint done",
    "typecheck:report": "node -e \"require('fs').mkdirSync('lintAndTypeError_Check',{recursive:true})\" && tsc --noEmit > lintAndTypeError_Check/typecheck-report.txt 2>&1 || echo typecheck done",
    "check:report": "npm run lint:report && npm run typecheck:report",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run tests/smoke --reporter=verbose"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "antd": "^6.0.1",
    "antd-style": "^3.7.1",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.556.0",
    "next": "16.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.2.0",
    "msw": "^2.12.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
